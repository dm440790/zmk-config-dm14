#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    // Maps this half's physical row/col matrix positions onto keymap
    // positions 0-29 (left half = first 30 keys of your 60-key keymap).
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <5>;

        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;

        // TODO: set to "row2col" instead if that's how your diodes are wired
        diode-direction = "col2row";

        // =====================================================================
        // TODO — REPLACE EVERY PIN NUMBER BELOW.
        // These are placeholders (sequential, not based on real wiring).
        // Numbers use nice!nano's "pro micro" pin numbering (0-21), matching
        // the pin labels silkscreened on the board (D0-D10, A0-A3, etc.),
        // NOT raw nRF52840 GPIO numbers.
        // Reference diagram: https://zmk.dev/docs/hardware/nice-nano
        // Trace each row/col trace on your PCB back to the nice!nano pad it
        // lands on, find that pad's pro-micro number on the diagram above,
        // and put it in the matching slot below.
        // =====================================================================
        row-gpios
            = <&pro_micro 4  GPIO_ACTIVE_HIGH>   // ROW0 - placeholder, replace
            , <&pro_micro 5  GPIO_ACTIVE_HIGH>   // ROW1 - placeholder, replace
            , <&pro_micro 6  GPIO_ACTIVE_HIGH>   // ROW2 - placeholder, replace
            , <&pro_micro 7  GPIO_ACTIVE_HIGH>   // ROW3 - placeholder, replace
            , <&pro_micro 8  GPIO_ACTIVE_HIGH>   // ROW4 - placeholder, replace
            ;

        col-gpios
            = <&pro_micro 15 GPIO_ACTIVE_HIGH>   // COL0 - placeholder, replace
            , <&pro_micro 14 GPIO_ACTIVE_HIGH>   // COL1 - placeholder, replace
            , <&pro_micro 16 GPIO_ACTIVE_HIGH>   // COL2 - placeholder, replace
            , <&pro_micro 10 GPIO_ACTIVE_HIGH>   // COL3 - placeholder, replace
            , <&pro_micro 9  GPIO_ACTIVE_HIGH>   // COL4 - placeholder, replace
            , <&pro_micro 20 GPIO_ACTIVE_HIGH>   // COL5 - placeholder, replace
            ;
    };
};
